    "\n",
    "# 7-day rolling averages\n",
    "df['trump_7d']  = df['Trump (%)'].rolling(7, min_periods=1).mean()\n",
    "df['harris_7d'] = df['Harris (%)'].rolling(7, min_periods=1).mean()\n",
    "df['spread']    = df['Trump (%)'] - df['Harris (%)']"
